NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb://mongo:27017/velocity
REDIS_URL=redis://redis:6379
INFOBIP_API_KEY=your_infobip_api_key_here
INFOBIP_BASE_URL=your_unique_url.infobip.com
JWT_SECRET=change_this_to_a_secure_random_32_chars
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGIN=http://localhost:3000
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
LOG_LEVEL=debug

# Copy this file to .env and fill real secrets. Never commit real .env to source control.NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/leadbooster?retryWrites=true&w=majority
REDIS_URL=redis://:password@localhost:6379
JWT_SECRET=your_super_secret_key_min_32_characters_long
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGIN=http://localhost:3000

# Optional
LOG_LEVEL=info
